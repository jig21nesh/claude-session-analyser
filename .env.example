# Claude Session Analyser — configuration
#
# Copy to `.env` to customise. Every variable is OPTIONAL and shown with its default.
#
# Note on API keys: there are none. The improvements engine and the cost forecast
# are deterministic (SQL heuristics + Holt-Winters smoothing) — no LLM is called,
# nothing leaves your machine, and no credentials are required.

# Port for the web UI (Vite dev server). Keep inside 11000-17999.
PORT=15800

# Port for the local API (binds to 127.0.0.1 only).
API_PORT=15801

# Where Claude Code stores session transcripts.
CLAUDE_PROJECTS_DIR=~/.claude/projects

# Where the analysis database is written.
ANALYSER_DB_PATH=./server/data/analyser.db

# Server log verbosity: debug | info | warn | error
LOG_LEVEL=info
